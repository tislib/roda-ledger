# Keep the Docker build context tiny. Anything listed here is never uploaded
# to the Docker daemon, so a full `COPY .` (or future additions) stays cheap.

# Build artifacts
target/
**/target/

# VCS
.git/
.gitignore
.gitattributes

# Editor / IDE
.idea/
.vscode/
*.swp
.DS_Store

# Docs and site output
docs/
book.toml
*.md
LICENSE

# Local runtime state — never ship host data into the image
data/
temp_*/
*.trace

# Dev scripts and ad-hoc tooling
dev/
scripts/

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
