# Copy to scripts/dev/.env (gitignored) and fill in your remote dev box.
# Keeps the host/path out of committed scripts.

# user@host, or an ~/.ssh/config alias, of your build box. Required by the remote helpers.
RODA_DEV_HOST=root@your-dev-box.example.com

# Repo path on the box (default: /root/roda-ledger).
#RODA_DEV_PATH=/root/roda-ledger
